## Detailed Code Diff Design

### Windows Diff (`windows/runner/flutter_window.cpp`)

```cpp
LRESULT
FlutterWindow::MessageHandler(HWND hwnd, UINT const message,
                              WPARAM const wparam,
                              LPARAM const lparam) noexcept {
  if (flutter_controller_) {
    std::optional<LRESULT> result =
        flutter_controller_->HandleTopLevelWindowProc(hwnd, message, wparam,
                                                      lparam);
    if (result) {
      return *result;
    }
  }

  switch (message) {
    case WM_ACTIVATE: {
      WORD active_state = LOWORD(wparam);
      HWND projector_wnd = FindNamedSubWindow(hwnd, L"KeryxPro Monitor 1");
      if (projector_wnd) {
        if (active_state == WA_INACTIVE) {
          SetWindowPos(projector_wnd, HWND_NOTOPMOST, 0, 0, 0, 0,
                       SWP_NOMOVE | SWP_NOSIZE | SWP_NOACTIVATE);
        } else {
          SetWindowPos(projector_wnd, HWND_TOPMOST, 0, 0, 0, 0,
                       SWP_NOMOVE | SWP_NOSIZE | SWP_NOACTIVATE);
        }
      }
      break; // Fall through to base class message handler
    }
    case WM_FONTCHANGE:
      flutter_controller_->engine()->ReloadSystemFonts();
      break;
  }

  return Win32Window::MessageHandler(hwnd, message, wparam, lparam);
}
```

### macOS Diff (`macos/Runner/MainFlutterWindow.swift`)

```swift
class MainFlutterWindow: NSWindow {
  // Existing awakeFromNib() and other code...

  override func becomeKey() {
    super.becomeKey()
    if let target = NSApp.windows.first(where: { $0.title == "KeryxPro Monitor 1" }) {
      target.level = .floating
    }
  }

  override func resignKey() {
    super.resignKey()
    if let target = NSApp.windows.first(where: { $0.title == "KeryxPro Monitor 1" }) {
      target.level = .normal
    }
  }
}
```

